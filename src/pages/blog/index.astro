---
import Base from "@/layouts/Base.astro";
import { getCollection } from "astro:content";
import { BRAND_NAME, SITE_URL } from "@/lib/config";
import { breadcrumbListSchema } from "@/lib/schema";

const posts = (await getCollection("blog"))
  .filter((p) => !p.data.draft)
  .sort(
    (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
  );

const canonical = `${SITE_URL}/blog`;
const jsonLd = breadcrumbListSchema([
  { name: "Home", url: SITE_URL },
  { name: "Blog", url: canonical },
]);

const dateFmt = new Intl.DateTimeFormat("en-US", {
  year: "numeric",
  month: "long",
  day: "numeric",
});
---

<Base
  title={`Blog | ${BRAND_NAME}`}
  description="Notes, analysis, and updates from the HumanizerBench team."
  canonical={canonical}
  ogImage={`${SITE_URL}/og/blog.png`}
  jsonLd={jsonLd}
>
  <section class="max-w-3xl mx-auto py-16 px-6">
    <header class="mb-12">
      <h1
        class="text-4xl font-semibold tracking-tight text-[var(--color-text-primary)]"
      >
        Blog
      </h1>
      <p class="mt-3 text-[var(--color-text-secondary)]">
        Notes, analysis, and updates from the HumanizerBench team.
      </p>
    </header>

    {
      posts.length === 0 ? (
        <p class="text-[var(--color-text-secondary)]">No posts yet.</p>
      ) : (
        <ul class="divide-y divide-[var(--color-border)] border-t border-b border-[var(--color-border)]">
          {posts.map((post) => (
            <li class="py-6">
              <article>
                <h2 class="text-xl font-semibold tracking-tight">
                  <a
                    href={`/blog/${post.id}`}
                    class="text-[var(--color-text-primary)] hover:text-[var(--color-accent)]"
                  >
                    {post.data.title}
                  </a>
                </h2>
                <p class="mt-2 text-sm text-[var(--color-text-secondary)]">
                  {post.data.description}
                </p>
                <div class="mt-3 flex flex-wrap items-center gap-x-3 gap-y-1 text-xs text-[var(--color-text-secondary)]">
                  <span>{post.data.author}</span>
                  <span aria-hidden="true">·</span>
                  <time datetime={post.data.pubDate.toISOString()}>
                    {dateFmt.format(post.data.pubDate)}
                  </time>
                </div>
              </article>
            </li>
          ))}
        </ul>
      )
    }
  </section>
</Base>
