---
import Base from "@/layouts/Base.astro";
import { getCollection, render, type CollectionEntry } from "astro:content";
import { BRAND_NAME, SITE_URL } from "@/lib/config";
import { articleSchema, breadcrumbListSchema } from "@/lib/schema";

export async function getStaticPaths() {
  const posts = (await getCollection("blog")).filter((p) => !p.data.draft);
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

interface Props {
  post: CollectionEntry<"blog">;
}

const { post } = Astro.props;
const { Content } = await render(post);

const canonical = `${SITE_URL}/blog/${post.id}`;

const jsonLd = [
  articleSchema({
    title: post.data.title,
    description: post.data.description,
    pubDate: post.data.pubDate,
    author: post.data.author,
    url: canonical,
  }),
  breadcrumbListSchema([
    { name: "Home", url: SITE_URL },
    { name: "Blog", url: `${SITE_URL}/blog` },
    { name: post.data.title, url: canonical },
  ]),
];

const dateFmt = new Intl.DateTimeFormat("en-US", {
  year: "numeric",
  month: "long",
  day: "numeric",
});
---

<Base
  title={`${post.data.title} — ${BRAND_NAME}`}
  description={post.data.description}
  canonical={canonical}
  ogImage={`${SITE_URL}/og/blog-${post.id}.png`}
  jsonLd={jsonLd}
>
  <article
    class="max-w-3xl mx-auto py-16 px-6 text-[var(--color-text-primary)] [&_h1]:text-4xl [&_h1]:font-semibold [&_h1]:tracking-tight [&_h1]:mb-6 [&_h2]:text-2xl [&_h2]:font-semibold [&_h2]:tracking-tight [&_h2]:mt-12 [&_h2]:mb-4 [&_h3]:text-xl [&_h3]:font-semibold [&_h3]:tracking-tight [&_h3]:mt-8 [&_h3]:mb-3 [&_p]:mt-4 [&_p]:leading-relaxed [&_p]:text-[var(--color-text-secondary)] [&_ul]:mt-4 [&_ul]:space-y-2 [&_ul]:pl-6 [&_ul]:list-disc [&_ul]:text-[var(--color-text-secondary)] [&_ol]:mt-4 [&_ol]:space-y-2 [&_ol]:pl-6 [&_ol]:list-decimal [&_ol]:text-[var(--color-text-secondary)] [&_a]:text-[var(--color-accent)] [&_a:hover]:underline [&_code]:font-mono [&_code]:text-[0.9em] [&_code]:px-1 [&_code]:py-0.5 [&_code]:rounded [&_code]:bg-[var(--color-surface)] [&_code]:border [&_code]:border-[var(--color-border)] [&_strong]:font-semibold [&_strong]:text-[var(--color-text-primary)] [&_em]:italic [&_blockquote]:mt-4 [&_blockquote]:border-l-2 [&_blockquote]:border-[var(--color-border)] [&_blockquote]:pl-4 [&_blockquote]:text-[var(--color-text-secondary)]"
  >
    <header class="mb-10 not-prose">
      <div
        class="flex flex-wrap items-center gap-x-3 gap-y-1 text-xs text-[var(--color-text-secondary)] mb-3"
      >
        <span>{post.data.author}</span>
        <span aria-hidden="true">·</span>
        <time datetime={post.data.pubDate.toISOString()}>
          {dateFmt.format(post.data.pubDate)}
        </time>
      </div>
    </header>
    <Content />
    <footer class="mt-16 pt-8 border-t border-[var(--color-border)]">
      <a
        href="/blog"
        class="text-sm text-[var(--color-accent)] hover:underline"
      >
        ← Back to blog
      </a>
    </footer>
  </article>
</Base>
