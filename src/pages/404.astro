---
import Base from "@/layouts/Base.astro";
import { BRAND_NAME, SITE_URL } from "@/lib/config";

const canonical = `${SITE_URL}/404`;
---

<Base
  title={`Page not found — ${BRAND_NAME}`}
  description="The page you were looking for doesn't exist or has moved."
  canonical={canonical}
>
  <section
    class="max-w-2xl mx-auto py-24 px-6 text-center text-[var(--color-text-primary)]"
  >
    <p
      class="text-sm font-mono uppercase tracking-widest text-[var(--color-text-secondary)]"
    >
      Error 404
    </p>
    <h1
      class="mt-4 text-5xl md:text-6xl font-semibold tracking-tight"
    >
      Page not found
    </h1>
    <p
      class="mt-6 text-lg leading-relaxed text-[var(--color-text-secondary)]"
    >
      The page you were looking for doesn't exist, has moved, or was
      retired with an older benchmark cycle. The current leaderboard and
      methodology are always one click away.
    </p>

    <div class="mt-10 flex flex-wrap items-center justify-center gap-3">
      <a
        href="/"
        class="inline-flex items-center rounded-md bg-[var(--color-accent)] px-4 py-2 text-sm font-medium text-white hover:opacity-90 transition-opacity"
      >
        Back to home
      </a>
      <a
        href="/leaderboard"
        class="inline-flex items-center rounded-md border border-[var(--color-border)] bg-[var(--color-surface)] px-4 py-2 text-sm font-medium text-[var(--color-text-primary)] hover:bg-[var(--color-bg)] transition-colors"
      >
        Latest leaderboard
      </a>
      <a
        href="/methodology"
        class="inline-flex items-center rounded-md border border-[var(--color-border)] bg-[var(--color-surface)] px-4 py-2 text-sm font-medium text-[var(--color-text-primary)] hover:bg-[var(--color-bg)] transition-colors"
      >
        Methodology
      </a>
    </div>

    <div
      class="mt-16 border-t border-[var(--color-border)] pt-8 text-left"
    >
      <h2
        class="text-sm font-semibold uppercase tracking-wide text-[var(--color-text-secondary)]"
      >
        Popular destinations
      </h2>
      <ul
        class="mt-4 grid gap-2 sm:grid-cols-2 text-[var(--color-text-secondary)]"
      >
        <li>
          <a
            href="/humanizers"
            class="text-[var(--color-accent)] hover:underline"
            >All humanizers</a
          >
        </li>
        <li>
          <a
            href="/detectors"
            class="text-[var(--color-accent)] hover:underline"
            >All detectors</a
          >
        </li>
        <li>
          <a
            href="/best-for"
            class="text-[var(--color-accent)] hover:underline"
            >Best for…</a
          >
        </li>
        <li>
          <a
            href="/blog"
            class="text-[var(--color-accent)] hover:underline"
            >Blog</a
          >
        </li>
        <li>
          <a
            href="/about"
            class="text-[var(--color-accent)] hover:underline"
            >About</a
          >
        </li>
        <li>
          <a
            href="/fairness"
            class="text-[var(--color-accent)] hover:underline"
            >Fairness &amp; corrections</a
          >
        </li>
      </ul>
    </div>
  </section>
</Base>
