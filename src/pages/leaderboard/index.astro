---
import Base from "@/layouts/Base.astro";
import FreshnessSignals from "@/components/FreshnessSignals.astro";
import LeaderboardTable from "@/components/LeaderboardTable.astro";
import ScoringExplainer from "@/components/ScoringExplainer.astro";
import SessionRecordings from "@/components/SessionRecordings.astro";
import CycleSelector from "@/components/CycleSelector.astro";
import { loadLatestCycle, loadHumanizerHistory } from "@/lib/data";
import { BRAND_NAME, SITE_URL, GITHUB_REPO_URL } from "@/lib/config";
import {
  datasetSchema,
  itemListSchema,
  breadcrumbListSchema,
} from "@/lib/schema";

const cycle = await loadLatestCycle();
const canonical = `${SITE_URL}/leaderboard`;

const jsonLd = [
  datasetSchema(cycle),
  itemListSchema(cycle.humanizers, canonical),
  breadcrumbListSchema([
    { name: "Home", url: SITE_URL },
    { name: "Leaderboard", url: canonical },
  ]),
];

const historyEntries = await Promise.all(
  cycle.humanizers.map(async (h) => {
    const hist = await loadHumanizerHistory(h.slug);
    return [h.slug, hist?.points.map((p) => p.composite) ?? null] as const;
  }),
);
const historyBySlug: Record<string, number[] | null> = Object.fromEntries(
  historyEntries,
);

const cycleDate = new Date(cycle.generated_at);
const monthYear = cycleDate.toLocaleString("en-US", {
  month: "long",
  year: "numeric",
  timeZone: "UTC",
});

const topConfidence = cycle.humanizers[0]?.confidence ?? "high";
const lastTested =
  cycle.humanizers[0]?.last_tested_at ?? cycle.generated_at;
---

<Base
  title={`Best AI Humanizer Leaderboard | ${BRAND_NAME}`}
  description={`Monthly ranking of ${cycle.humanizers.length} AI humanizers across 6 detectors. Updated ${monthYear}.`}
  canonical={canonical}
  ogImage={`${SITE_URL}/og/leaderboard.png`}
  jsonLd={jsonLd}
>
  <section class="max-w-7xl mx-auto px-4 py-12 md:py-16">
    <div class="mb-8 flex flex-wrap items-end justify-between gap-4">
      <div>
        <h1 class="text-3xl md:text-4xl font-semibold tracking-tight text-[var(--color-text-primary)]">
          AI Humanizer Leaderboard
        </h1>
        <p class="mt-2 text-[var(--color-text-secondary)]">
          Cycle: <span class="font-mono tabnum">{cycle.cycle}</span> • {cycle.cycle_sample_count} samples per humanizer
        </p>
      </div>
      <CycleSelector current={cycle.cycle} />
    </div>

    <div class="mb-6">
      <FreshnessSignals
        lastTested={lastTested}
        sampleCount={cycle.cycle_sample_count}
        confidence={topConfidence}
        methodologyVersion={cycle.methodology_version}
      />
    </div>

    <LeaderboardTable
      data={cycle.humanizers}
      historyBySlug={historyBySlug}
    />

    {cycle.recording_sessions && cycle.recording_sessions.length > 0 && (
      <div class="mt-10">
        <SessionRecordings sessions={cycle.recording_sessions} />
      </div>
    )}

    <div class="mt-10">
      <ScoringExplainer />
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-4 mt-10">
      <div class="rounded-xl border border-[var(--color-border)] bg-[var(--color-surface)] p-6">
        <h2 class="text-[11px] uppercase tracking-[0.14em] font-medium text-[var(--color-text-secondary)]">
          Archives
        </h2>
        <ul class="mt-3 space-y-2 text-sm">
          <li>
            <a
              href={`/leaderboard/${cycle.cycle}`}
              class="text-[var(--color-text-primary)] hover:text-[var(--color-accent)] transition-colors"
            >
              {cycle.cycle} →
            </a>
          </li>
        </ul>
      </div>

      <div class="rounded-xl border border-[var(--color-border)] bg-[var(--color-surface)] p-6">
        <h2 class="text-[11px] uppercase tracking-[0.14em] font-medium text-[var(--color-text-secondary)]">
          How we score
        </h2>
        <ul class="mt-3 space-y-2 text-sm">
          <li>
            <a
              href="/methodology"
              class="text-[var(--color-text-primary)] hover:text-[var(--color-accent)] transition-colors"
            >
              Methodology →
            </a>
          </li>
          <li>
            <a
              href="/fairness"
              class="text-[var(--color-text-primary)] hover:text-[var(--color-accent)] transition-colors"
            >
              Fairness policy →
            </a>
          </li>
        </ul>
      </div>

      <div class="rounded-xl border border-[var(--color-border)] bg-[var(--color-surface)] p-6">
        <h2 class="text-[11px] uppercase tracking-[0.14em] font-medium text-[var(--color-text-secondary)]">
          Raw data
        </h2>
        <ul class="mt-3 space-y-2 text-sm">
          <li>
            <a
              href="/api/leaderboard.json"
              class="text-[var(--color-text-primary)] hover:text-[var(--color-accent)] transition-colors"
            >
              /api/leaderboard.json →
            </a>
          </li>
          <li>
            <a
              href={GITHUB_REPO_URL}
              target="_blank"
              rel="noopener noreferrer"
              class="text-[var(--color-text-primary)] hover:text-[var(--color-accent)] transition-colors"
            >
              GitHub repo →
            </a>
          </li>
        </ul>
      </div>
    </div>
  </section>
</Base>
