---
import Base from "@/layouts/Base.astro";
import {
  BRAND_NAME,
  SITE_URL,
  PARENT_ORG_URL,
  GITHUB_REPO_URL,
} from "@/lib/config";
import { breadcrumbListSchema } from "@/lib/schema";

const canonical = `${SITE_URL}/fairness`;
const jsonLd = breadcrumbListSchema([
  { name: "Home", url: SITE_URL },
  { name: "Fairness", url: canonical },
]);
---

<Base
  title={`Fairness & Corrections — ${BRAND_NAME}`}
  description="How vendors can dispute results, request retesting, submit API access, and audit our benchmark."
  canonical={canonical}
  ogImage={`${SITE_URL}/og/fairness.png`}
  jsonLd={jsonLd}
>
  <article
    class="max-w-3xl mx-auto py-16 px-6 text-[var(--color-text-primary)] [&_h1]:text-4xl [&_h1]:font-semibold [&_h1]:tracking-tight [&_h1]:mb-8 [&_h2]:text-2xl [&_h2]:font-semibold [&_h2]:tracking-tight [&_h2]:mt-12 [&_h2]:mb-4 [&_p]:mt-4 [&_p]:leading-relaxed [&_p]:text-[var(--color-text-secondary)] [&_ul]:mt-4 [&_ul]:space-y-2 [&_ul]:pl-6 [&_ul]:list-disc [&_ul]:text-[var(--color-text-secondary)] [&_ol]:mt-4 [&_ol]:space-y-2 [&_ol]:pl-6 [&_ol]:list-decimal [&_ol]:text-[var(--color-text-secondary)] [&_a]:text-[var(--color-accent)] [&_a:hover]:underline [&_code]:font-mono [&_code]:text-[0.9em] [&_code]:px-1 [&_code]:py-0.5 [&_code]:rounded [&_code]:bg-[var(--color-surface)] [&_code]:border [&_code]:border-[var(--color-border)] [&_strong]:font-semibold [&_strong]:text-[var(--color-text-primary)]"
  >
    <h1>Fairness &amp; Corrections</h1>

    <h2>How rankings are computed</h2>
    <p>
      Every rank on HumanizerBench comes from a deterministic scoring script
      run over a published cycle of inputs, humanized outputs, and detector
      responses. We do not hand-edit rankings. For the full formula, weights,
      and penalty rules, read the <a href="/methodology">methodology page</a>.
    </p>

    <h2>What we publish that you can audit</h2>
    <ul>
      <li>All input prompts and their <code>prompt_set_version</code>.</li>
      <li>All humanized outputs, per humanizer, per sample.</li>
      <li>
        All detector responses — both raw API payloads and our parsed
        classification — for every humanized output.
      </li>
      <li>The scoring script (Python) in our public repository.</li>
      <li>
        Methodology and config version history (<code>methodology_version</code
        >, <code>scoring_version</code>, <code>prompt_set_version</code>, <code
          >detector_config_version</code
        >, <code>humanizer_config_version</code>).
      </li>
      <li>
        Repository: <a
          href={GITHUB_REPO_URL}
          rel="noopener noreferrer"
          target="_blank">{GITHUB_REPO_URL}</a
        >.
      </li>
    </ul>

    <h2>How to dispute a result</h2>
    <p>
      Email <a href="mailto:disputes@humanizerbench.example"
        >disputes@humanizerbench.example</a
      > with the subject line
      <code>Dispute — [Cycle] — [Humanizer]</code>. Include:
    </p>
    <ol>
      <li>Which result you dispute (cycle ID, humanizer, sample ID).</li>
      <li>
        Reproducible evidence — the exact input, your expected output, and how
        the published output differs.
      </li>
      <li>
        Any details about your test setup (account tier, plan, configuration
        flags, region, time of day).
      </li>
    </ol>
    <p>We respond within 14 business days.</p>

    <h2>How to request retesting</h2>
    <p>
      Submit a retest request to <a href="mailto:retest@humanizerbench.example"
        >retest@humanizerbench.example</a
      > with:
    </p>
    <ol>
      <li>Which humanizer should be retested.</li>
      <li>
        What has changed since the last cycle (new model, new pricing tier,
        new endpoint, bug fix).
      </li>
      <li>
        Your preferred API access details, if available. Retests run on the
        next cycle.
      </li>
    </ol>

    <h2>How to submit API access</h2>
    <p>
      Vendors who'd like to be tested via API instead of through their UI:
      email <a href="mailto:api@humanizerbench.example"
        >api@humanizerbench.example</a
      > with API documentation, authentication method, rate limits, and any
      usage costs we'll incur. We will not modify a score retroactively because
      a vendor changed integration paths after a cycle ran.
    </p>

    <h2>What we won't do</h2>
    <ul>
      <li>Adjust rankings outside the published methodology.</li>
      <li>Exclude tools because they outperform WriteHuman.</li>
      <li>Accept payment for placement on any leaderboard.</li>
      <li>
        Modify a humanizer's score after publication without versioning the
        change.
      </li>
      <li>Run private tests off the record.</li>
    </ul>

    <h2>WriteHuman disclosure</h2>
    <p>
      HumanizerBench is operated by WriteHuman (<a
        href={PARENT_ORG_URL}
        rel="noopener noreferrer"
        target="_blank">{PARENT_ORG_URL}</a
      >). We disclose this on every page. The longer version of <a href="/why"
        >why we built this and how we handle the conflict</a
      > is on its own page. Our anti-bias commitments:
    </p>
    <ol>
      <li>
        WriteHuman is tested using the exact same methodology and scoring as
        every other humanizer.
      </li>
      <li>The scoring script is public and deterministic.</li>
      <li>
        We have never adjusted rankings to favor WriteHuman, and we will
        publicly document any future change to methodology, scoring, or
        penalty rules.
      </li>
    </ol>
  </article>
</Base>
