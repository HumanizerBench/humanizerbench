---
import Base from "@/layouts/Base.astro";
import FreshnessSignals from "@/components/FreshnessSignals.astro";
import RankChange from "@/components/RankChange.astro";
import HeadToHead from "@/components/HeadToHead.tsx";
import { loadCycle } from "@/lib/data";
import { BRAND_NAME, SITE_URL } from "@/lib/config";
import { DETECTORS, type DetectorSlug } from "@/lib/detectors";
import {
  listAllVsPairs,
  comparisonSlug,
} from "@/lib/comparisons";
import { fmtComposite } from "@/lib/format";
import type { Humanizer } from "@/lib/types";
import { breadcrumbListSchema, softwareApplicationSchema } from "@/lib/schema";
import Favicon from "@/components/Favicon.astro";

export async function getStaticPaths() {
  const pairs = await listAllVsPairs();
  return pairs.map(({ a, b, cycleId, isCurrent }) => ({
    params: { comparison: comparisonSlug([a, b]) },
    props: { aSlug: a, bSlug: b, cycleId, isCurrent },
  }));
}

interface Props {
  aSlug: string;
  bSlug: string;
  cycleId: string;
  isCurrent: boolean;
}

const { aSlug, bSlug, cycleId, isCurrent } = Astro.props;
const comparison = comparisonSlug([aSlug, bSlug]);

// Load from the cycle where both humanizers coexisted (may not be current).
const cycle = await loadCycle(cycleId);
const findBySlug = (s: string) =>
  cycle.humanizers.find((h) => h.slug === s);
const a = findBySlug(aSlug);
const b = findBySlug(bSlug);
if (!a || !b) {
  throw new Error(
    `Could not find humanizers for comparison: ${aSlug} vs ${bSlug} in cycle ${cycleId}`,
  );
}

const winner =
  a.scores.composite > b.scores.composite
    ? "a"
    : b.scores.composite > a.scores.composite
      ? "b"
      : null;

const title = `${a.name} vs ${b.name} — AI Humanizer Comparison — ${BRAND_NAME}`;
const description = `Compare ${a.name} and ${b.name}: overall scores, detector bypass rates, pricing. Independent monthly benchmark data.`;
const canonical = `${SITE_URL}/vs/${comparison}`;

const jsonLd = [
  breadcrumbListSchema([
    { name: "Home", url: SITE_URL },
    { name: "Leaderboard", url: `${SITE_URL}/leaderboard` },
    { name: `${a.name} vs ${b.name}`, url: canonical },
  ]),
  softwareApplicationSchema(a),
  softwareApplicationSchema(b),
];

const lastTested =
  a.last_tested_at > b.last_tested_at ? a.last_tested_at : b.last_tested_at;
const lowerConfidence: "high" | "medium" | "low" =
  a.confidence === "low" || b.confidence === "low"
    ? "low"
    : a.confidence === "medium" || b.confidence === "medium"
      ? "medium"
      : "high";

const detectorSlugs = Object.keys(a.detector_breakdown);

function fmtPct(n: number | null | undefined): string {
  if (typeof n !== "number" || !Number.isFinite(n)) return "—";
  return (n * 100).toFixed(1);
}
function fmtMonthly(p: Humanizer["pricing"]): string {
  if (p.monthly_usd == null) return "—";
  if (p.monthly_usd === 0) return "Free";
  return `$${p.monthly_usd.toFixed(2)}/mo`;
}

const cardBase =
  "relative rounded-xl border p-6 transition-colors";
const cardLoser =
  "border-[var(--color-border)] bg-[var(--color-surface)]/50";
const cardWinner =
  "border-transparent medal-gold ring-2 ring-[color-mix(in_srgb,var(--medal-gold-text)_55%,transparent)] shadow-sm";

// Render winner on the left (loser on the right). Tie → alphabetical order.
const displayOrder: Humanizer[] =
  winner === "b" ? [b, a] : [a, b];
---

<Base
  title={title}
  description={description}
  canonical={canonical}
  ogImage={`${SITE_URL}/og/vs-${comparison}.png`}
  jsonLd={jsonLd}
>
  <section class="max-w-6xl mx-auto px-4 py-12 md:py-16">
    <nav
      class="text-xs text-[var(--color-text-secondary)] mb-4 flex items-center gap-2"
    >
      <a href="/leaderboard" class="hover:text-[var(--color-text-primary)]"
        >Leaderboard</a
      >
      <span>/</span>
      <span class="text-[var(--color-text-primary)]">
        {a.name} vs {b.name}
      </span>
    </nav>

    {!isCurrent && (
      <div class="mb-6 rounded-lg border border-[var(--color-border)] bg-[var(--color-surface)] px-4 py-3 text-sm text-[var(--color-text-secondary)] flex flex-wrap items-baseline gap-x-2">
        <span class="text-[var(--color-text-primary)] font-medium">Not in the current cycle.</span>
        <span>Data shown is from <a href={`/leaderboard/${cycleId}`} class="text-[var(--color-text-primary)] underline decoration-[var(--color-border)] underline-offset-4 hover:decoration-[var(--color-accent)]">cycle {cycleId}</a>, the most recent cycle where both {a.name} and {b.name} were tested together.</span>
      </div>
    )}

    <h1
      class="text-3xl md:text-4xl font-semibold tracking-tight text-[var(--color-text-primary)]"
    >
      {a.name} vs {b.name}
    </h1>
    <p class="mt-2 text-[var(--color-text-secondary)]">
      Head-to-head from the <span class="font-mono tabnum">{cycle.cycle}</span> cycle
      benchmark
    </p>

    <div class="mt-6">
      <FreshnessSignals
        lastTested={lastTested}
        sampleCount={cycle.cycle_sample_count}
        confidence={lowerConfidence}
        methodologyVersion={cycle.methodology_version}
      />
    </div>

    <div class="mt-8 grid grid-cols-1 md:grid-cols-2 gap-4">
      {displayOrder.map((h, idx) => {
        const isWinner = winner !== null && idx === 0;
        return (
          <div class:list={[cardBase, isWinner ? cardWinner : cardLoser]}>
            {isWinner && (
              <span
                class="absolute -top-3 left-6 inline-flex items-center gap-1.5 rounded-full bg-[var(--medal-gold-text)] px-2.5 py-1 text-[10px] uppercase tracking-wider font-semibold text-white shadow-sm"
                aria-label="Winner of this matchup"
              >
                <span aria-hidden="true">🥇</span> Winner
              </span>
            )}
            <div class="flex items-center gap-3">
              <Favicon url={h.url} name={h.name} size={48} />
              <div class="min-w-0">
                <div class="text-lg font-semibold text-[var(--color-text-primary)] truncate">
                  <a
                    href={`/humanizers/${h.slug}`}
                    class="hover:text-[var(--color-accent)]"
                  >
                    {h.name}
                  </a>
                </div>
                <a
                  href={h.url}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="text-xs text-[var(--color-text-secondary)] hover:text-[var(--color-accent)] truncate block"
                >
                  {h.url.replace(/^https?:\/\//, "")}
                </a>
              </div>
              <div class="ml-auto text-right">
                <div class="text-[10px] uppercase tracking-wider text-[var(--color-text-secondary)]">
                  Rank
                </div>
                <div class="font-mono tabnum text-lg text-[var(--color-text-primary)]">
                  #{h.rank}
                </div>
              </div>
            </div>

            <div class="mt-5 flex items-baseline gap-2">
              <div class="font-mono tabnum text-4xl text-[var(--color-text-primary)]">
                {fmtComposite(h.scores.composite)}
              </div>
              <div class="text-sm text-[var(--color-text-secondary)]">
                overall
              </div>
              <div class="ml-auto"><RankChange change={h.rank_change} /></div>
            </div>

            <dl class="mt-5 grid grid-cols-3 gap-x-4 gap-y-3 text-sm">
              <div>
                <dt class="text-[10px] uppercase tracking-wider text-[var(--color-text-secondary)]">
                  Bypass
                </dt>
                <dd class="font-mono tabnum text-[var(--color-text-primary)]">
                  {fmtPct(h.scores.bypass_rate)}
                </dd>
              </div>
              <div>
                <dt class="text-[10px] uppercase tracking-wider text-[var(--color-text-secondary)]">
                  Meaning
                </dt>
                <dd class="font-mono tabnum text-[var(--color-text-primary)]">
                  {fmtPct(h.scores.meaning_preservation)}
                </dd>
              </div>
              <div>
                <dt class="text-[10px] uppercase tracking-wider text-[var(--color-text-secondary)]">
                  Readability
                </dt>
                <dd class="font-mono tabnum text-[var(--color-text-primary)]">
                  {fmtPct(h.scores.readability)}
                </dd>
              </div>
            </dl>
          </div>
        );
      })}
    </div>

    <div class="mt-10">
      <h2
        class="text-xl font-semibold text-[var(--color-text-primary)] mb-4"
      >
        Side-by-side metrics
      </h2>
      <div
        class="rounded-xl border border-[var(--color-border)] bg-[var(--color-surface)]/50 p-4 md:p-6"
      >
        <HeadToHead client:visible humanizerA={a} humanizerB={b} />
      </div>
    </div>

    <div class="mt-10">
      <h2
        class="text-xl font-semibold text-[var(--color-text-primary)] mb-4"
      >
        Detector-level breakdown
      </h2>
      <p class="text-sm text-[var(--color-text-secondary)] mb-4">
        Gold cell wins each row.
      </p>
      <div class="rounded-xl border border-[var(--color-border)] bg-[var(--color-surface)]">
        <table class="w-full text-sm">
          <thead>
            <tr class="text-[var(--color-text-secondary)] border-b border-[var(--color-border)]">
              <th class="px-4 py-3 font-medium uppercase tracking-wider text-xs text-left">
                Detector
              </th>
              <th class="px-4 py-3 font-medium uppercase tracking-wider text-xs text-right">
                {a.name}
              </th>
              <th class="px-4 py-3 font-medium uppercase tracking-wider text-xs text-right">
                {b.name}
              </th>
            </tr>
          </thead>
          <tbody>
            {detectorSlugs.map((slug) => {
              const av = a.detector_breakdown[slug] ?? 0;
              const bv = b.detector_breakdown[slug] ?? 0;
              const displayName =
                DETECTORS[slug as DetectorSlug]?.name ?? slug;
              const aWins = av > bv;
              const bWins = bv > av;
              return (
                <tr class="border-t border-[var(--color-border)]">
                  <td class="px-4 align-middle whitespace-nowrap text-left text-[var(--color-text-primary)] h-[56px]">
                    {displayName}
                  </td>
                  <td class:list={["px-4 align-middle whitespace-nowrap text-right", aWins && "medal-gold"]}>
                    <span class="font-mono tabnum font-medium">{fmtPct(av)}</span>
                  </td>
                  <td class:list={["px-4 align-middle whitespace-nowrap text-right", bWins && "medal-gold"]}>
                    <span class="font-mono tabnum font-medium">{fmtPct(bv)}</span>
                  </td>
                </tr>
              );
            })}
          </tbody>
        </table>
      </div>
    </div>

    <div class="mt-10">
      <h2
        class="text-xl font-semibold text-[var(--color-text-primary)] mb-4"
      >
        Pricing
      </h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        {[a, b].map((h) => (
          <div
            class="rounded-xl border border-[var(--color-border)] bg-[var(--color-surface)]/50 p-6"
          >
            <div class="text-sm text-[var(--color-text-secondary)] mb-1">
              {h.name}
            </div>
            <div class="font-mono tabnum text-2xl text-[var(--color-text-primary)]">
              {fmtMonthly(h.pricing)}
            </div>
            <dl class="mt-4 grid grid-cols-2 gap-3 text-sm">
              <div>
                <dt class="text-[10px] uppercase tracking-wider text-[var(--color-text-secondary)]">
                  Free tier
                </dt>
                <dd class="text-[var(--color-text-primary)]">
                  {h.pricing.free_tier ? "Yes" : "No"}
                </dd>
              </div>
              <div>
                <dt class="text-[10px] uppercase tracking-wider text-[var(--color-text-secondary)]">
                  Free word limit
                </dt>
                <dd class="font-mono tabnum text-[var(--color-text-primary)]">
                  {h.pricing.free_tier_word_limit ?? "—"}
                </dd>
              </div>
            </dl>
          </div>
        ))}
      </div>
    </div>

    <div
      class="mt-12 rounded-xl border border-[var(--color-border)] bg-[var(--color-surface)]/40 p-6 text-sm"
    >
      <div class="text-[var(--color-text-secondary)] mb-3">Related</div>
      <ul class="grid grid-cols-1 md:grid-cols-2 gap-2">
        <li>
          <a
            href={`/humanizers/${a.slug}`}
            class="text-[var(--color-text-primary)] hover:text-[var(--color-accent)]"
          >
            {a.name} — full review →
          </a>
        </li>
        <li>
          <a
            href={`/humanizers/${b.slug}`}
            class="text-[var(--color-text-primary)] hover:text-[var(--color-accent)]"
          >
            {b.name} — full review →
          </a>
        </li>
        <li>
          <a
            href="/leaderboard"
            class="text-[var(--color-text-primary)] hover:text-[var(--color-accent)]"
          >
            Full leaderboard →
          </a>
        </li>
        <li>
          <a
            href="/methodology"
            class="text-[var(--color-text-primary)] hover:text-[var(--color-accent)]"
          >
            Methodology →
          </a>
        </li>
      </ul>
    </div>
  </section>
</Base>
