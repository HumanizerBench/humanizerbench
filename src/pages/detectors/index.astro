---
import Base from "@/layouts/Base.astro";
import { DETECTORS } from "@/lib/detectors";
import { SITE_URL } from "@/lib/config";
import { breadcrumbListSchema } from "@/lib/schema";

const detectorEntries = Object.entries(DETECTORS);
const canonical = `${SITE_URL}/detectors`;

const jsonLd = breadcrumbListSchema([
  { name: "Home", url: SITE_URL },
  { name: "Detectors", url: canonical },
]);
---

<Base
  title="AI Detectors Tested | Bypass Scores by Detector | HumanizerBench"
  description="We test every AI humanizer against 6 leading detectors: GPTZero, Originality.ai, Copyleaks, Winston AI, Sapling, ZeroGPT. See which humanizer wins each."
  canonical={canonical}
  ogImage={`${SITE_URL}/og/detectors.png`}
  jsonLd={jsonLd}
>
  <section class="max-w-7xl mx-auto px-4 py-12 md:py-16">
    <div class="mb-10">
      <h1 class="text-3xl md:text-4xl font-semibold tracking-tight text-[var(--color-text-primary)]">
        AI Detectors We Test Against
      </h1>
      <p class="mt-3 text-[var(--color-text-secondary)] max-w-2xl">
        Every humanizer is run against six independent AI-text detectors each cycle. Pick a detector to see which humanizers bypass it most reliably.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
      {
        detectorEntries.map(([slug, info]) => (
          <a
            href={`/detectors/${slug}`}
            class="rounded-xl border border-[var(--color-border)] bg-[var(--color-surface)]/50 p-6 hover:bg-[var(--color-surface)] transition-colors block"
          >
            <div class="flex flex-col gap-2">
              <span class="text-xl font-medium text-[var(--color-text-primary)]">
                {info.name}
              </span>
              <span class="text-xs text-[var(--color-text-secondary)]">
                {info.url.replace(/^https?:\/\//, "")}
              </span>
              <p class="text-sm text-[var(--color-text-secondary)] mt-2">
                {info.blurb}
              </p>
              <span class="text-sm text-[var(--color-accent)] mt-3">
                View bypass ranking →
              </span>
            </div>
          </a>
        ))
      }
    </div>

    <p class="mt-10 text-sm text-[var(--color-text-secondary)] max-w-2xl">
      Bypass rate is the fraction of samples a detector marks as human-written. For the full method, see
      <a href="/methodology" class="text-[var(--color-accent)] hover:underline">
        how we measure bypass rate
      </a>.
    </p>
  </section>
</Base>
