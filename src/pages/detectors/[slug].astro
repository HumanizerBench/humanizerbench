---
import Base from "@/layouts/Base.astro";
import FreshnessSignals from "@/components/FreshnessSignals.astro";
import DetectorLeaderboardTable from "@/components/DetectorLeaderboardTable.astro";
import ScoringExplainer from "@/components/ScoringExplainer.astro";
import { DETECTORS, type DetectorSlug } from "@/lib/detectors";
import { loadLatestCycle } from "@/lib/data";
import { SITE_URL } from "@/lib/config";
import { itemListSchema, breadcrumbListSchema } from "@/lib/schema";

export async function getStaticPaths() {
  return Object.keys(DETECTORS).map((slug) => ({ params: { slug } }));
}

const { slug } = Astro.params;
const detectorSlug = slug as DetectorSlug;
const detector = DETECTORS[detectorSlug];

if (!detector) {
  throw new Error(`Unknown detector slug: ${slug}`);
}

const cycle = await loadLatestCycle();

const ranked = [...cycle.humanizers].sort(
  (a, b) =>
    (b.detector_breakdown[detectorSlug] ?? 0) -
    (a.detector_breakdown[detectorSlug] ?? 0),
);
const topThree = ranked.slice(0, 3);

const lastTested = cycle.humanizers[0]?.last_tested_at ?? cycle.generated_at;
const topConfidence = cycle.humanizers[0]?.confidence ?? "high";
const canonical = `${SITE_URL}/detectors/${slug}`;

const jsonLd = [
  itemListSchema(ranked, canonical),
  breadcrumbListSchema([
    { name: "Home", url: SITE_URL },
    { name: "Detectors", url: `${SITE_URL}/detectors` },
    { name: detector.name, url: canonical },
  ]),
];
---

<Base
  title={`Best AI Humanizer for ${detector.name} — Bypass Rankings — HumanizerBench`}
  description={`Which AI humanizer best bypasses ${detector.name}? Monthly tests of ${cycle.humanizers.length} humanizers. ${cycle.cycle_sample_count} samples. All data public.`}
  canonical={canonical}
  ogImage={`${SITE_URL}/og/detector-${slug}.png`}
  jsonLd={jsonLd}
>
  <section class="max-w-7xl mx-auto px-4 py-12 md:py-16">
    <div class="mb-6">
      <a
        href="/detectors"
        class="text-xs text-[var(--color-text-secondary)] hover:text-[var(--color-accent)]"
      >
        ← All detectors
      </a>
    </div>

    <div class="mb-8">
      <h1 class="text-3xl md:text-4xl font-semibold tracking-tight text-[var(--color-text-primary)]">
        Best for {detector.name}
      </h1>
      <p class="mt-3 text-[var(--color-text-secondary)] max-w-2xl">
        Humanizers ranked by their measured bypass rate against {detector.name}.
      </p>
    </div>

    <div class="mb-6 rounded-xl border border-[var(--color-border)] bg-[var(--color-surface)]/50 p-5">
      <div class="flex flex-wrap items-baseline gap-x-3 gap-y-1">
        <span class="text-lg font-medium text-[var(--color-text-primary)]">
          {detector.name}
        </span>
        <a
          href={detector.url}
          target="_blank"
          rel="noopener noreferrer"
          class="text-xs text-[var(--color-text-secondary)] hover:text-[var(--color-accent)]"
        >
          {detector.url.replace(/^https?:\/\//, "")} ↗
        </a>
      </div>
      <p class="mt-2 text-sm text-[var(--color-text-secondary)]">
        {detector.blurb}
      </p>
    </div>

    <div class="mb-6">
      <FreshnessSignals
        lastTested={lastTested}
        sampleCount={cycle.cycle_sample_count}
        confidence={topConfidence}
        methodologyVersion={cycle.methodology_version}
      />
    </div>

    <DetectorLeaderboardTable
      humanizers={cycle.humanizers}
      detectorSlug={detectorSlug}
      detectorName={detector.name}
    />

    <p class="mt-6 text-sm text-[var(--color-text-secondary)] max-w-3xl">
      Higher bypass rate alone ≠ a better tool. See the balanced overall ranking on the
      <a href="/leaderboard" class="text-[var(--color-accent)] hover:underline">
        main leaderboard
      </a>.
    </p>

    <div class="mt-10">
      <ScoringExplainer />
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mt-10">
      <div class="rounded-lg border border-[var(--color-border)] bg-[var(--color-surface)] p-5">
        <h2 class="text-sm font-medium uppercase tracking-wider text-[var(--color-text-secondary)]">
          Top 3 for {detector.name}
        </h2>
        <ol class="mt-3 space-y-2 text-sm list-decimal list-inside">
          {
            topThree.map((h) => (
              <li>
                <a
                  href={`/humanizers/${h.slug}`}
                  class="text-[var(--color-text-primary)] hover:text-[var(--color-accent)]"
                >
                  {h.name}
                </a>
                <span class="ml-2 text-xs text-[var(--color-text-secondary)] font-mono tabnum">
                  {(
                    (h.detector_breakdown[detectorSlug] ?? 0) * 100
                  ).toFixed(1)}%
                </span>
              </li>
            ))
          }
        </ol>
      </div>

      <div class="rounded-lg border border-[var(--color-border)] bg-[var(--color-surface)] p-5">
        <h2 class="text-sm font-medium uppercase tracking-wider text-[var(--color-text-secondary)]">
          Related
        </h2>
        <ul class="mt-3 space-y-2 text-sm">
          <li>
            <a
              href="/methodology"
              class="text-[var(--color-text-primary)] hover:text-[var(--color-accent)]"
            >
              How we measure bypass →
            </a>
          </li>
          <li>
            <a
              href="/leaderboard"
              class="text-[var(--color-text-primary)] hover:text-[var(--color-accent)]"
            >
              Main leaderboard →
            </a>
          </li>
          <li>
            <a
              href="/detectors"
              class="text-[var(--color-text-primary)] hover:text-[var(--color-accent)]"
            >
              All detectors →
            </a>
          </li>
        </ul>
      </div>
    </div>
  </section>
</Base>
