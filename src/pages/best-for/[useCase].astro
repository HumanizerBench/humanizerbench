---
import Base from "@/layouts/Base.astro";
import FreshnessSignals from "@/components/FreshnessSignals.astro";
import Favicon from "@/components/Favicon.astro";
import PenaltyChip from "@/components/PenaltyChip.astro";
import TrendSparkline from "@/components/TrendSparkline.astro";
import ColumnHeaderTooltip from "@/components/ColumnHeaderTooltip.astro";
import { loadLatestCycle, loadHumanizerHistory } from "@/lib/data";
import { applyUseCaseSort } from "@/lib/scoring";
import { fmtComposite } from "@/lib/format";
import {
  BEST_FOR_USE_CASES,
  BRAND_NAME,
  SITE_URL,
  GITHUB_REPO_URL,
  type BestForUseCase,
} from "@/lib/config";
import { itemListSchema, breadcrumbListSchema } from "@/lib/schema";
import type { Humanizer } from "@/lib/types";

export async function getStaticPaths() {
  return BEST_FOR_USE_CASES.map((useCase) => ({
    params: { useCase: useCase.slug },
    props: { useCase },
  }));
}

interface Props {
  useCase: BestForUseCase;
}

const { useCase } = Astro.props as Props;

const cycle = await loadLatestCycle();
const ranked = applyUseCaseSort(cycle.humanizers, useCase.slug);
const top10 = ranked.slice(0, 10);

const historyEntries = await Promise.all(
  top10.map(async (h) => {
    const hist = await loadHumanizerHistory(h.slug);
    return [h.slug, hist?.points.map((p) => p.composite) ?? null] as const;
  }),
);
const historyBySlug: Record<string, number[] | null> = Object.fromEntries(
  historyEntries,
);

const title = `${useCase.label} — ${BRAND_NAME}`;
const description = `Top AI humanizers for ${useCase.targetQuery}. ${useCase.displayedSortLogic}. Independent monthly benchmark from ${BRAND_NAME}.`;
const canonical = `${SITE_URL}/best-for/${useCase.slug}`;

const jsonLd = [
  ...(top10.length > 0 ? [itemListSchema(top10, canonical)] : []),
  breadcrumbListSchema([
    { name: "Home", url: SITE_URL },
    { name: "Leaderboard", url: `${SITE_URL}/leaderboard` },
    { name: useCase.label, url: canonical },
  ]),
];

const lastTested =
  cycle.humanizers[0]?.last_tested_at ?? cycle.generated_at;
const topConfidence = cycle.humanizers[0]?.confidence ?? "high";

function fmtScore(v: number | null | undefined): string {
  if (typeof v !== "number" || !Number.isFinite(v)) return "—";
  return (v * 100).toFixed(1);
}

function formatRelative(iso: string): string {
  const then = new Date(iso).getTime();
  if (!Number.isFinite(then)) return "—";
  const now = Date.now();
  const diffMs = now - then;
  const day = 24 * 60 * 60 * 1000;
  const days = Math.floor(diffMs / day);
  if (days < 1) {
    const hours = Math.max(1, Math.floor(diffMs / (60 * 60 * 1000)));
    return `${hours}h ago`;
  }
  if (days < 30) return `${days}d ago`;
  const months = Math.floor(days / 30);
  if (months < 12) return `${months}mo ago`;
  const years = Math.floor(days / 365);
  return `${years}y ago`;
}

type Medal = "gold" | "silver" | "bronze";
const MEDAL_BY_RANK: Medal[] = ["gold", "silver", "bronze"];
const MEDAL_EMOJI: Record<Medal, string> = {
  gold: "🥇",
  silver: "🥈",
  bronze: "🥉",
};

function buildMedals(
  rows: Humanizer[],
  pick: (h: Humanizer) => number | null | undefined,
): Map<string, Medal> {
  const m = new Map<string, Medal>();
  const entries = rows
    .map((h) => ({ slug: h.slug, v: pick(h) }))
    .filter((e): e is { slug: string; v: number } => typeof e.v === "number");
  entries.sort((a, b) => b.v - a.v);
  let medalIdx = 0;
  let prevValue: number | null = null;
  for (const e of entries) {
    if (prevValue !== null && e.v !== prevValue) medalIdx++;
    if (medalIdx > 2) break;
    m.set(e.slug, MEDAL_BY_RANK[medalIdx]!);
    prevValue = e.v;
  }
  return m;
}

const medals = {
  composite: buildMedals(top10, (h) => h.scores.composite),
  bypass_rate: buildMedals(top10, (h) => h.scores.bypass_rate),
  meaning: buildMedals(top10, (h) => h.scores.meaning_preservation),
  readability: buildMedals(top10, (h) => h.scores.readability),
};

const otherUseCases = BEST_FOR_USE_CASES.filter(
  (uc) => uc.slug !== useCase.slug,
);
---

<Base
  title={title}
  description={description}
  canonical={canonical}
  ogImage={`${SITE_URL}/og/best-for-${useCase.slug}.png`}
  jsonLd={jsonLd}
>
  <section class="max-w-7xl mx-auto px-4 py-12 md:py-16">
    <nav
      class="text-xs text-[var(--color-text-secondary)] mb-4 flex items-center gap-2"
    >
      <a href="/leaderboard" class="hover:text-[var(--color-text-primary)]">
        Leaderboard
      </a>
      <span>/</span>
      <span class="text-[var(--color-text-primary)]">{useCase.label}</span>
    </nav>

    <h1
      class="text-3xl md:text-4xl font-semibold tracking-tight text-[var(--color-text-primary)]"
    >
      {useCase.label}
    </h1>
    <p class="mt-2 text-[var(--color-text-secondary)]">
      Cycle <span class="font-mono tabnum">{cycle.cycle}</span> • re-ranked for
      this use case
    </p>

    <div
      class="mt-6 bg-[var(--color-surface)] border border-[var(--color-border)] rounded-xl p-4 text-sm"
    >
      <div
        class="text-[10px] uppercase tracking-wider text-[var(--color-text-secondary)] mb-1"
      >
        How we ranked these
      </div>
      <div class="text-[var(--color-text-primary)]">
        {useCase.displayedSortLogic}
      </div>
    </div>

    <div class="mt-6">
      <FreshnessSignals
        lastTested={lastTested}
        sampleCount={cycle.cycle_sample_count}
        confidence={topConfidence}
        methodologyVersion={cycle.methodology_version}
      />
    </div>

    {
      top10.length === 0 ? (
        <div
          class="mt-10 rounded-xl border border-[var(--color-border)] bg-[var(--color-surface)]/50 p-8 text-center text-[var(--color-text-secondary)]"
        >
          No humanizers matched this use case's filter.
        </div>
      ) : (
        <div class="mt-8 rounded-lg border border-[var(--color-border)] bg-[var(--color-surface)] overflow-x-auto">
          <table class="w-full caption-bottom text-sm">
            <thead
              class="sticky top-0 z-10 bg-[var(--color-bg)] border-b border-[var(--color-border)]"
            >
              <tr>
                <th
                  scope="col"
                  class="h-10 px-3 align-middle text-xs font-medium uppercase tracking-wider text-[var(--color-text-secondary)] whitespace-nowrap text-left"
                >
                  <ColumnHeaderTooltip
                    label="Rank"
                    description="Position in this use-case ranking."
                    align="start"
                  />
                </th>
                <th
                  scope="col"
                  class="h-10 px-3 align-middle text-xs font-medium uppercase tracking-wider text-[var(--color-text-secondary)] whitespace-nowrap text-left"
                >
                  Humanizer
                </th>
                <th
                  scope="col"
                  class="h-10 px-3 align-middle text-xs font-medium uppercase tracking-wider text-[var(--color-text-secondary)] whitespace-nowrap text-right"
                >
                  <ColumnHeaderTooltip
                    label="Overall"
                    description="Weighted blend of bypass rate, meaning preservation, readability, consistency, and speed. Penalties may reduce this score."
                  />
                </th>
                <th
                  scope="col"
                  class="h-10 px-3 align-middle text-xs font-medium uppercase tracking-wider text-[var(--color-text-secondary)] whitespace-nowrap text-right"
                >
                  <ColumnHeaderTooltip
                    label="Bypass Rate"
                    description="Fraction of detector tests where the humanized output was classified as human, across all 6 detectors."
                  />
                </th>
                <th
                  scope="col"
                  class="h-10 px-3 align-middle text-xs font-medium uppercase tracking-wider text-[var(--color-text-secondary)] whitespace-nowrap text-right"
                >
                  <ColumnHeaderTooltip
                    label="Meaning"
                    description="Semantic similarity (embedding cosine) between input and humanized output. Higher = output preserves the input's meaning."
                  />
                </th>
                <th
                  scope="col"
                  class="h-10 px-3 align-middle text-xs font-medium uppercase tracking-wider text-[var(--color-text-secondary)] whitespace-nowrap text-right"
                >
                  <ColumnHeaderTooltip
                    label="Readability"
                    description="Inverse of reading-level drift between input and output. Higher = closer to the input's reading level."
                  />
                </th>
                <th
                  scope="col"
                  class="h-10 px-3 align-middle text-xs font-medium uppercase tracking-wider text-[var(--color-text-secondary)] whitespace-nowrap text-right"
                >
                  <ColumnHeaderTooltip
                    label="Penalties"
                    description="Total points deducted from the overall score when output-quality issues were detected. Hover a row's chip to see why."
                  />
                </th>
                <th
                  scope="col"
                  class="h-10 px-3 align-middle text-xs font-medium uppercase tracking-wider text-[var(--color-text-secondary)] whitespace-nowrap text-center"
                >
                  Trend
                </th>
                <th
                  scope="col"
                  class="h-10 px-3 align-middle text-xs font-medium uppercase tracking-wider text-[var(--color-text-secondary)] whitespace-nowrap text-right"
                >
                  Last Tested
                </th>
              </tr>
            </thead>
            <tbody>
              {top10.map((h) => {
                const compositePct = fmtComposite(h.scores.composite);
                const history = historyBySlug[h.slug] ?? null;
                return (
                  <tr class="h-[72px] border-b border-[var(--color-border)] last:border-0 hover:bg-[var(--color-surface)]/50 transition-colors">
                    <td class="px-3 align-middle whitespace-nowrap text-left">
                      <span
                        class="font-mono tabnum font-medium text-[var(--color-text-primary)]"
                        style="font-size: 28px; line-height: 1;"
                      >
                        {h.rank}
                      </span>
                    </td>
                    <td class="px-3 align-middle whitespace-nowrap text-left">
                      <div class="flex items-center gap-3">
                        <Favicon url={h.url} name={h.name} size={24} />
                        <div class="flex flex-col leading-tight min-w-0">
                          <a
                            href={`/humanizers/${h.slug}`}
                            class="font-medium text-[var(--color-text-primary)] hover:text-[var(--color-accent)]"
                          >
                            {h.name}
                          </a>
                          <a
                            href={h.url}
                            target="_blank"
                            rel="noopener noreferrer"
                            class="text-xs text-[var(--color-text-secondary)] hover:text-[var(--color-accent)] truncate"
                          >
                            {h.url.replace(/^https?:\/\//, "")}
                          </a>
                        </div>
                      </div>
                    </td>
                    <td
                      class:list={[
                        "px-3 align-middle whitespace-nowrap text-right",
                        medals.composite.has(h.slug) &&
                          `medal-${medals.composite.get(h.slug)}`,
                      ]}
                    >
                      {medals.composite.has(h.slug) && (
                        <span class="mr-1.5" aria-hidden="true">
                          {MEDAL_EMOJI[medals.composite.get(h.slug)!]}
                        </span>
                      )}
                      <span class="font-mono tabnum font-medium">
                        {compositePct}
                      </span>
                    </td>
                    <td
                      class:list={[
                        "px-3 align-middle whitespace-nowrap text-right",
                        medals.bypass_rate.has(h.slug) &&
                          `medal-${medals.bypass_rate.get(h.slug)}`,
                      ]}
                    >
                      <span class="font-mono tabnum font-medium">
                        {fmtScore(h.scores.bypass_rate)}
                      </span>
                    </td>
                    <td
                      class:list={[
                        "px-3 align-middle whitespace-nowrap text-right",
                        medals.meaning.has(h.slug) &&
                          `medal-${medals.meaning.get(h.slug)}`,
                      ]}
                    >
                      <span class="font-mono tabnum font-medium">
                        {fmtScore(h.scores.meaning_preservation)}
                      </span>
                    </td>
                    <td
                      class:list={[
                        "px-3 align-middle whitespace-nowrap text-right",
                        medals.readability.has(h.slug) &&
                          `medal-${medals.readability.get(h.slug)}`,
                      ]}
                    >
                      <span class="font-mono tabnum font-medium">
                        {fmtScore(h.scores.readability)}
                      </span>
                    </td>
                    <td class="px-3 align-middle whitespace-nowrap text-right">
                      <PenaltyChip penalties={h.penalties_applied ?? []} />
                    </td>
                    <td class="px-3 align-middle whitespace-nowrap">
                      <div class="flex justify-center">
                        <TrendSparkline points={history} />
                      </div>
                    </td>
                    <td class="px-3 align-middle whitespace-nowrap text-right">
                      <span class="text-xs text-[var(--color-text-secondary)] tabnum">
                        {formatRelative(h.last_tested_at)}
                      </span>
                    </td>
                  </tr>
                );
              })}
            </tbody>
          </table>
        </div>
      )
    }

    <div
      class="mt-10 rounded-xl border border-[var(--color-border)] bg-[var(--color-surface)]/40 p-6 text-sm"
    >
      <div class="text-[var(--color-text-secondary)] mb-3">Dig deeper</div>
      <ul class="grid grid-cols-1 md:grid-cols-2 gap-2">
        <li>
          <a
            href="/leaderboard"
            class="text-[var(--color-text-primary)] hover:text-[var(--color-accent)]"
          >
            See full data on /leaderboard →
          </a>
        </li>
        <li>
          <a
            href="/methodology"
            class="text-[var(--color-text-primary)] hover:text-[var(--color-accent)]"
          >
            Read methodology →
          </a>
        </li>
        <li>
          <a
            href="/api/leaderboard.json"
            class="text-[var(--color-text-primary)] hover:text-[var(--color-accent)]"
          >
            Raw data: /api/leaderboard.json →
          </a>
        </li>
        <li>
          <a
            href={GITHUB_REPO_URL}
            target="_blank"
            rel="noopener noreferrer"
            class="text-[var(--color-text-primary)] hover:text-[var(--color-accent)]"
          >
            Scoring scripts on GitHub →
          </a>
        </li>
      </ul>
    </div>

    <div class="mt-10">
      <h2
        class="text-sm font-medium uppercase tracking-wider text-[var(--color-text-secondary)] mb-3"
      >
        Other use cases
      </h2>
      <ul class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-2">
        {otherUseCases.map((uc) => (
          <li>
            <a
              href={`/best-for/${uc.slug}`}
              class="block rounded-lg border border-[var(--color-border)] bg-[var(--color-surface)]/40 px-4 py-3 text-sm text-[var(--color-text-primary)] hover:border-[var(--color-accent)]/50 hover:text-[var(--color-accent)]"
            >
              {uc.label}
            </a>
          </li>
        ))}
      </ul>
    </div>
  </section>
</Base>
