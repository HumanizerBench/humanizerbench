---
import Base from "@/layouts/Base.astro";
import RankChange from "@/components/RankChange.astro";
import { listHumanizers } from "@/lib/data";
import { BRAND_NAME, SITE_URL } from "@/lib/config";
import { itemListSchema, breadcrumbListSchema } from "@/lib/schema";
import { fmtComposite } from "@/lib/format";
import Favicon from "@/components/Favicon.astro";

const humanizers = (await listHumanizers()).slice().sort((a, b) => a.rank - b.rank);
const count = humanizers.length;
const canonical = `${SITE_URL}/humanizers`;

const jsonLd = [
  itemListSchema(humanizers, canonical),
  breadcrumbListSchema([
    { name: "Home", url: SITE_URL },
    { name: "Humanizers", url: canonical },
  ]),
];
---

<Base
  title={`AI Humanizer Comparison — All Tools Tested — ${BRAND_NAME}`}
  description={`Side-by-side comparison of every AI humanizer in our benchmark. ${count} tools, monthly testing, all data public.`}
  canonical={canonical}
  ogImage={`${SITE_URL}/og/humanizers.png`}
  jsonLd={jsonLd}
>
  <section class="max-w-7xl mx-auto px-4 py-12 md:py-16">
    <div class="mb-10">
      <h1 class="text-3xl md:text-4xl font-semibold tracking-tight text-[var(--color-text-primary)]">
        AI Humanizers
      </h1>
      <p class="mt-2 text-[var(--color-text-secondary)] max-w-2xl">
        Every humanizer in the current benchmark cycle, ranked by overall score.
        Click into any tool for detector-by-detector breakdowns, category performance,
        12-month trend, and pricing.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      {
        humanizers.map((h) => {
          const composite = fmtComposite(h.scores.composite);
          const host = (() => {
            try {
              return new URL(h.url).host.replace(/^www\./, "");
            } catch {
              return h.url;
            }
          })();
          return (
            <a
              href={`/humanizers/${h.slug}`}
              class="block rounded-xl border border-[var(--color-border)] bg-[var(--color-surface)]/50 p-6 hover:bg-[var(--color-surface)] transition-colors"
            >
              <div class="flex items-center gap-3">
                <Favicon url={h.url} name={h.name} size={24} />
                <div class="min-w-0 flex-1">
                  <div class="text-base font-medium text-[var(--color-text-primary)] truncate">
                    {h.name}
                  </div>
                  <div class="text-xs text-[var(--color-text-secondary)] truncate">
                    {host}
                  </div>
                </div>
              </div>

              <div class="mt-5 flex items-baseline gap-3">
                <span class="font-mono tabnum text-2xl text-[var(--color-text-primary)]">
                  {composite}
                </span>
                <RankChange change={h.rank_change} />
              </div>
              <div class="mt-1 text-xs text-[var(--color-text-secondary)] font-mono tabnum">
                #{h.rank}
              </div>
            </a>
          );
        })
      }
    </div>
  </section>
</Base>
