---
interface Props {
  label: string;
  description: string;
  learnMoreHref?: string;
  /**
   * Where the popover should anchor. "start" aligns left edge to the trigger
   * (use for left-aligned columns); "end" aligns right edge (use for
   * right-aligned numeric columns to keep the popover inside the table).
   */
  align?: "start" | "end";
}

const {
  label,
  description,
  learnMoreHref = "/methodology",
  align = "end",
} = Astro.props;
---

<span class="col-header-tt" data-align={align}>
  <span class="col-header-tt-label"><slot>{label}</slot></span>
  <button
    type="button"
    class="col-header-tt-icon"
    aria-label={`About ${label}`}
    aria-describedby={`tt-${label.replace(/\s+/g, "-").toLowerCase()}`}
    onclick="event.stopPropagation()"
  >
    <svg
      viewBox="0 0 16 16"
      width="11"
      height="11"
      fill="none"
      stroke="currentColor"
      stroke-width="1.4"
      aria-hidden="true"
    >
      <circle cx="8" cy="8" r="6.5"></circle>
      <path d="M8 11.5V7.5"></path>
      <circle cx="8" cy="5" r="0.6" fill="currentColor" stroke="none"></circle>
    </svg>
  </button>
  <span
    class="col-header-tt-popover"
    id={`tt-${label.replace(/\s+/g, "-").toLowerCase()}`}
    role="tooltip"
    onclick="event.stopPropagation()"
  >
    <p class="col-header-tt-desc">{description}</p>
    <a
      href={learnMoreHref}
      class="col-header-tt-link"
      onclick="event.stopPropagation()"
    >
      Learn more →
    </a>
  </span>
</span>

<style>
  .col-header-tt {
    position: relative;
    display: inline-flex;
    align-items: center;
    gap: 4px;
  }

  .col-header-tt-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 14px;
    height: 14px;
    padding: 0;
    border: 0;
    background: transparent;
    color: var(--color-text-secondary);
    cursor: help;
    border-radius: 9999px;
    opacity: 0.7;
    transition: opacity 0.12s ease, color 0.12s ease;
  }

  .col-header-tt:hover .col-header-tt-icon,
  .col-header-tt:focus-within .col-header-tt-icon {
    opacity: 1;
    color: var(--color-text-primary);
    outline: none;
  }

  .col-header-tt-popover {
    position: absolute;
    top: 100%;
    z-index: 60;
    min-width: 240px;
    max-width: 320px;
    margin-top: 6px;
    padding: 10px 12px;
    border-radius: 8px;
    border: 1px solid rgb(228 228 231);
    background: #ffffff;
    box-shadow: 0 12px 32px rgb(0 0 0 / 0.18);
    color: #18181b;
    text-align: left;
    white-space: normal;
    text-transform: none;
    letter-spacing: normal;
    font-weight: 400;
    opacity: 0;
    visibility: hidden;
    transform: translateY(-2px);
    transition: opacity 0.12s ease, transform 0.12s ease, visibility 0.12s;
    pointer-events: none;
  }

  :global([data-theme="dark"]) .col-header-tt-popover {
    background: #2c2853;
    border-color: rgb(81 79 122);
    color: #f1efff;
    box-shadow: 0 12px 32px rgb(0 0 0 / 0.5);
  }

  /* Invisible bridge so the cursor can move from the icon to the popover
     without losing :hover on the parent. */
  .col-header-tt-popover::before {
    content: "";
    position: absolute;
    top: -6px;
    left: 0;
    right: 0;
    height: 6px;
  }

  .col-header-tt[data-align="end"] .col-header-tt-popover {
    right: 0;
  }

  .col-header-tt[data-align="start"] .col-header-tt-popover {
    left: 0;
  }

  .col-header-tt:hover .col-header-tt-popover,
  .col-header-tt:focus-within .col-header-tt-popover {
    opacity: 1;
    visibility: visible;
    transform: translateY(0);
    pointer-events: auto;
  }

  .col-header-tt-desc {
    margin: 0 0 6px;
    font-size: 12px;
    line-height: 1.45;
    color: var(--color-text-secondary);
  }

  .col-header-tt-link {
    font-size: 12px;
    color: var(--color-accent);
    text-decoration: none;
  }

  .col-header-tt-link:hover {
    text-decoration: underline;
  }
</style>
