---
interface Props {
  change: number;
}

const { change } = Astro.props;
const abs = Math.abs(change);
---

{
  change > 0 ? (
    <span class="font-mono tabnum text-xs font-medium text-[var(--color-accent-up)]">
      ▲ {abs}
    </span>
  ) : change < 0 ? (
    <span class="font-mono tabnum text-xs font-medium text-[var(--color-accent-down)]">
      ▼ {abs}
    </span>
  ) : (
    <span class="font-mono tabnum text-xs font-medium text-[var(--color-text-secondary)]">
      -
    </span>
  )
}
