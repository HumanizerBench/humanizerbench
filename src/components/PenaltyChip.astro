---
import type { Penalty } from "@/lib/types";
import {
  fmtPenaltyDelta,
  getPenaltyMeta,
  summarizePenalties,
} from "@/lib/penalties";

interface Props {
  penalties: Penalty[];
}

const { penalties } = Astro.props;
const summary = summarizePenalties(penalties);
---

{
  penalties.length === 0 ? (
    <span class="no-penalty-chip" aria-label="No penalties">
      <svg
        viewBox="0 0 16 16"
        width="11"
        height="11"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        aria-hidden="true"
      >
        <path d="M3 8.5L6.5 12L13 4.5" />
      </svg>
      <span>None</span>
    </span>
  ) : (
    <span class="penalty-chip-wrap">
      <span
        class="penalty-chip"
        tabindex="0"
        aria-describedby="penalty-popover"
      >
        <svg
          viewBox="0 0 16 16"
          width="11"
          height="11"
          fill="none"
          stroke="currentColor"
          stroke-width="1.4"
          stroke-linejoin="round"
          stroke-linecap="round"
          aria-hidden="true"
        >
          <path d="M8 2L14.5 13H1.5L8 2z" />
          <path d="M8 6.5V9.5" />
          <circle cx="8" cy="11.5" r="0.5" fill="currentColor" stroke="none" />
        </svg>
        <span class="font-mono tabnum">
          {fmtPenaltyDelta(summary.totalDelta)}
        </span>
        {summary.count > 1 && (
          <span class="penalty-chip-count font-mono tabnum">×{summary.count}</span>
        )}
      </span>
      <span class="penalty-popover" role="tooltip">
        <span class="penalty-popover-title">Penalties applied</span>
        <ul class="penalty-popover-list">
          {penalties.map((p) => {
            const meta = getPenaltyMeta(p.code);
            const atMax =
              meta != null && Math.abs(p.score_delta) >= meta.cap - 0.05;
            return (
              <li>
                <div class="penalty-popover-row">
                  <span class="penalty-popover-label">
                    {meta?.label ?? p.code}
                  </span>
                  <span class="penalty-popover-delta font-mono tabnum">
                    {fmtPenaltyDelta(p.score_delta)}
                  </span>
                </div>
                {meta && (
                  <div class="penalty-popover-meta">
                    <span class="font-mono tabnum">
                      Applied {p.count}×
                    </span>
                    <span aria-hidden="true">·</span>
                    <span class="font-mono tabnum">
                      max {fmtPenaltyDelta(-meta.cap)}
                    </span>
                    {atMax && <span class="penalty-popover-at-max">at max</span>}
                  </div>
                )}
                {meta && (
                  <p class="penalty-popover-desc">{meta.description}</p>
                )}
              </li>
            );
          })}
        </ul>
      </span>
    </span>
  )
}

<style>
  .no-penalty-chip {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    padding: 2px 8px;
    border-radius: 9999px;
    border: 1px solid rgb(16 185 129 / 0.35);
    background: rgb(16 185 129 / 0.12);
    color: rgb(16 185 129);
    font-size: 12px;
    line-height: 1.4;
  }

  .penalty-chip-wrap {
    position: relative;
    display: inline-block;
  }

  .penalty-chip {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    padding: 2px 8px;
    border-radius: 9999px;
    background: rgb(220 38 38 / 0.10);
    color: rgb(185 28 28);
    font-size: 12px;
    font-weight: 500;
    line-height: 1.4;
    cursor: help;
    outline: none;
  }

  .penalty-chip:hover {
    background: rgb(220 38 38 / 0.16);
  }

  .penalty-chip:focus-visible {
    box-shadow: 0 0 0 2px rgb(220 38 38 / 0.35);
  }

  :global([data-theme="dark"]) .penalty-chip {
    background: rgb(248 113 113 / 0.14);
    color: rgb(252 165 165);
  }

  :global([data-theme="dark"]) .penalty-chip:hover {
    background: rgb(248 113 113 / 0.22);
  }

  .penalty-chip-count {
    color: inherit;
    font-size: 11px;
    opacity: 0.7;
  }

  .penalty-popover {
    position: absolute;
    top: 100%;
    right: 0;
    z-index: 60;
    min-width: 280px;
    max-width: 360px;
    margin-top: 6px;
    padding: 10px 12px;
    border-radius: 8px;
    border: 1px solid rgb(228 228 231);
    background: #ffffff;
    box-shadow: 0 12px 32px rgb(0 0 0 / 0.18);
    color: #18181b;
    text-align: left;
    white-space: normal;
    opacity: 0;
    visibility: hidden;
    transform: translateY(-2px);
    transition: opacity 0.12s ease, transform 0.12s ease, visibility 0.12s;
    pointer-events: none;
  }

  :global([data-theme="dark"]) .penalty-popover {
    background: #2c2853;
    border-color: rgb(81 79 122);
    color: #f1efff;
    box-shadow: 0 12px 32px rgb(0 0 0 / 0.5);
  }

  /* Hover bridge so the cursor can move from the chip into the popover. */
  .penalty-popover::before {
    content: "";
    position: absolute;
    top: -6px;
    left: 0;
    right: 0;
    height: 6px;
  }

  .penalty-chip-wrap:hover .penalty-popover,
  .penalty-chip-wrap:focus-within .penalty-popover {
    opacity: 1;
    visibility: visible;
    transform: translateY(0);
    pointer-events: auto;
  }

  .penalty-popover-title {
    display: block;
    font-size: 11px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-text-secondary);
    margin-bottom: 8px;
  }

  .penalty-popover-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .penalty-popover-list li {
    border-bottom: 1px solid var(--color-border);
    padding-bottom: 6px;
  }

  .penalty-popover-list li:last-child {
    border-bottom: 0;
    padding-bottom: 0;
  }

  .penalty-popover-row {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 8px;
  }

  .penalty-popover-label {
    font-size: 13px;
    font-weight: 500;
    color: var(--color-text-primary);
  }

  .penalty-popover-count {
    margin-left: 4px;
    font-size: 11px;
    color: var(--color-text-secondary);
  }

  .penalty-popover-delta {
    font-size: 13px;
    color: rgb(220 38 38);
    font-weight: 500;
  }

  .penalty-popover-meta {
    margin-top: 4px;
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: 11px;
    color: var(--color-text-secondary);
    line-height: 1.4;
  }

  .penalty-popover-at-max {
    display: inline-flex;
    align-items: center;
    padding: 1px 6px;
    border-radius: 9999px;
    background: rgb(220 38 38 / 0.12);
    color: rgb(185 28 28);
    font-size: 10px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  :global([data-theme="dark"]) .penalty-popover-at-max {
    background: rgb(248 113 113 / 0.18);
    color: rgb(252 165 165);
  }

  .penalty-popover-desc {
    margin-top: 6px;
    font-size: 12px;
    line-height: 1.4;
    color: var(--color-text-secondary);
  }
</style>
