---
interface Props {
  lastTested: string;
  sampleCount: number;
  confidence: "high" | "medium" | "low";
  methodologyVersion: string;
}

const { lastTested, sampleCount, confidence, methodologyVersion } = Astro.props;

const labelClass =
  "uppercase tracking-wider text-xs text-[var(--color-text-secondary)]";
const valueClass = "font-mono text-sm text-[var(--color-text-primary)] tabnum";
---

<div
  class="grid grid-cols-2 md:grid-cols-4 gap-4 border border-[var(--color-border)] rounded-lg bg-[var(--color-surface)] p-4"
>
  <div>
    <div class={labelClass}>Last tested</div>
    <time datetime={lastTested} class={valueClass}>
      {new Date(lastTested).toISOString().slice(0, 10)}
    </time>
  </div>
  <div>
    <div class={labelClass}>Sample size</div>
    <div class={valueClass}>{sampleCount}</div>
  </div>
  <div>
    <div class={labelClass}>Confidence</div>
    <div class={valueClass}>{confidence}</div>
  </div>
  <div>
    <div class={labelClass}>Methodology</div>
    <div class={valueClass}>v{methodologyVersion}</div>
  </div>
</div>
