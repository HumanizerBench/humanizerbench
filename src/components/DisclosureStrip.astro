---
import { GITHUB_REPO_URL, PARENT_ORG } from "@/lib/config";
---

<div
  class="w-full border-b border-[var(--color-border)] bg-[var(--color-surface)] text-[var(--color-text-secondary)] text-xs py-2 px-4"
>
  <div class="max-w-7xl mx-auto">
    Operated by {PARENT_ORG}. Methodology and raw data:{" "}
    <a
      href={GITHUB_REPO_URL}
      class="underline decoration-dotted underline-offset-2 hover:text-[var(--color-accent)]"
      target="_blank"
      rel="noopener"
    >
      GitHub
    </a>
  </div>
</div>
