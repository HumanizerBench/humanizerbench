---
interface Props {
  score: number | null | undefined;
  display?: string;
  class?: string;
}

const { score, display, class: className } = Astro.props;

const isValid = typeof score === "number" && Number.isFinite(score);
const clamped = isValid ? Math.min(1, Math.max(0, score as number)) : 0;
const text = isValid
  ? (display ?? ((score as number) * 100).toFixed(1))
  : "-";
---

<span
  class:list={[
    "inline-flex flex-col items-end gap-1.5 font-mono tabnum align-middle",
    className,
  ]}
>
  <span class="leading-none">{text}</span>
  {
    isValid && (
      <span
        aria-hidden="true"
        class="relative inline-block h-1 w-16 rounded-full overflow-hidden"
        style="background: var(--color-border);"
      >
        <span
          class="absolute inset-y-0 left-0 rounded-full"
          style={`width: ${clamped * 100}%; background: var(--color-accent);`}
        />
      </span>
    )
  }
</span>
