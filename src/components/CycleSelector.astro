---
import { listCycles } from "@/lib/data";

interface Props {
  current: string;
  class?: string;
}

const { current, class: className } = Astro.props;
const cycles = await listCycles();

function formatLabel(id: string): string {
  const m = id.match(/^(\d{4})-(\d{2})$/);
  if (!m) return id;
  const [, y, mo] = m;
  const d = new Date(Number(y), Number(mo) - 1, 1);
  return d.toLocaleString("en-US", {
    month: "long",
    year: "numeric",
    timeZone: "UTC",
  });
}
---

<div class:list={["inline-flex items-center gap-2", className]}>
  <label
    for="cycle-selector"
    class="text-xs uppercase tracking-wider text-[var(--color-text-secondary)]"
  >
    Cycle
  </label>
  <select
    id="cycle-selector"
    data-cycle-selector
    aria-label="Jump to a cycle"
    class="h-8 min-w-[160px] rounded-md border border-[var(--color-border)] bg-[var(--color-surface)] px-2.5 text-sm text-[var(--color-text-primary)] focus:outline-none focus:ring-2 focus:ring-[var(--color-accent)]/50"
  >
    {
      cycles.map((id) => (
        <option value={id} selected={id === current}>
          {formatLabel(id)}
        </option>
      ))
    }
  </select>
</div>

<script>
  document
    .querySelectorAll<HTMLSelectElement>("[data-cycle-selector]")
    .forEach((sel) => {
      sel.addEventListener("change", () => {
        const id = sel.value;
        if (!id) return;
        window.location.href = `/leaderboard/${id}`;
      });
    });
</script>
