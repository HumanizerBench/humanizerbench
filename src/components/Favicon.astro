---
interface Props {
  url: string;
  name: string;
  size?: number;
  class?: string;
}

const { url, name, size = 24, class: className } = Astro.props;

let host = "";
try {
  host = new URL(url).host.replace(/^www\./, "");
} catch {
  /* fall through to monogram */
}

const initial = name.charAt(0).toUpperCase();
// Request 2x the display size so retina screens stay crisp.
const reqSize = Math.max(32, size * 2);
const src = host
  ? `https://www.google.com/s2/favicons?domain=${host}&sz=${reqSize}`
  : "";
const fontSize = Math.max(10, Math.round(size * 0.46));
---

{
  host ? (
    <img
      src={src}
      width={size}
      height={size}
      alt=""
      loading="lazy"
      decoding="async"
      class:list={[
        "rounded-md object-contain bg-[var(--color-bg)] border border-[var(--color-border)] shrink-0",
        className,
      ]}
      style={`width: ${size}px; height: ${size}px; padding: 2px;`}
    />
  ) : (
    <span
      aria-hidden="true"
      class:list={[
        "inline-flex items-center justify-center rounded-md bg-[var(--color-bg)] border border-[var(--color-border)] font-medium text-[var(--color-text-primary)] shrink-0",
        className,
      ]}
      style={`width: ${size}px; height: ${size}px; font-size: ${fontSize}px;`}
    >
      {initial}
    </span>
  )
}
