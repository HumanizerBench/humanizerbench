---
import type { RecordingSession } from "@/lib/types";

interface Props {
  sessions: RecordingSession[];
}

const { sessions } = Astro.props;

function formatDuration(ms: number): string {
  const total = Math.max(0, Math.round(ms / 1000));
  const m = Math.floor(total / 60);
  const s = total % 60;
  return `${m}:${String(s).padStart(2, "0")}`;
}

function formatStartedAt(iso: string): string {
  const d = new Date(iso);
  const date = d.toISOString().slice(0, 10);
  const time = d.toISOString().slice(11, 16);
  return `${date} · ${time} UTC`;
}
---

{sessions.length > 0 && (
  <section
    id="session-recordings"
    class="rounded-xl border border-[var(--color-border)] bg-[var(--color-surface)] p-6 md:p-8"
    aria-labelledby="session-recordings-title"
  >
    <div class="flex flex-wrap items-baseline justify-between gap-2 mb-2">
      <h2
        id="session-recordings-title"
        class="text-lg font-medium text-[var(--color-text-primary)]"
      >
        Session recordings
      </h2>
      <a
        href="/methodology"
        class="text-sm text-[var(--color-accent)] hover:underline"
      >
        See the full methodology →
      </a>
    </div>
    <p class="text-sm text-[var(--color-text-secondary)] mb-5">
      Screen captures from the benchmark runs, kept for auditability. Hosted
      links may expire over time; the JSON in this repo is the source of truth.
    </p>

    <ul class="divide-y divide-[var(--color-border)] border-y border-[var(--color-border)]">
      {sessions.map((s) => (
        <li class="py-3">
          <button
            type="button"
            data-toggle-session
            data-session-id={s.id}
            data-expanded="false"
            aria-controls={`session-panel-${s.id}`}
            aria-expanded="false"
            class="w-full flex items-center justify-between gap-4 text-left group"
          >
            <span class="flex flex-wrap items-baseline gap-x-4 gap-y-1">
              <span class="font-mono tabnum text-sm text-[var(--color-text-primary)]">
                {formatStartedAt(s.started_at)}
              </span>
              <span class="text-xs text-[var(--color-text-secondary)]">
                {formatDuration(s.total_duration_ms)} ·{" "}
                {s.segment_count}{" "}
                {s.segment_count === 1 ? "segment" : "segments"}
                {s.test_markers.length > 0 && (
                  <span>{" "}· {s.test_markers.length} markers</span>
                )}
              </span>
            </span>
            <span
              class="text-xs text-[var(--color-text-secondary)] group-hover:text-[var(--color-accent)] transition-colors shrink-0"
              aria-hidden="true"
              data-icon
            >
              ↓
            </span>
          </button>

          <div
            id={`session-panel-${s.id}`}
            data-session-panel={s.id}
            hidden
            class="mt-4 space-y-4"
          >
            {s.segment_urls.map((url, i) => (
              <div>
                {s.segment_count > 1 && (
                  <p class="text-[10px] uppercase tracking-wider text-[var(--color-text-secondary)] mb-1">
                    Segment {i + 1} of {s.segment_count}
                  </p>
                )}
                <video
                  controls
                  preload="metadata"
                  playsinline
                  class="w-full rounded-md border border-[var(--color-border)] bg-black"
                  src={url}
                ></video>
              </div>
            ))}

            {s.test_markers.length > 0 && (
              <div>
                <h3 class="text-[11px] uppercase tracking-[0.14em] font-medium text-[var(--color-text-secondary)] mb-2">
                  Test markers
                </h3>
                <ul class="space-y-1.5">
                  {s.test_markers.map((m) => (
                    <li class="text-xs flex flex-wrap items-baseline gap-x-3 gap-y-0.5">
                      <span class="font-mono tabnum text-[var(--color-text-primary)] w-12 shrink-0">
                        {formatDuration(m.offset_ms)}
                      </span>
                      <span class="text-[var(--color-text-secondary)]">
                        <span class="text-[var(--color-text-primary)]">
                          {m.humanizer_slug}
                        </span>{" "}
                        · {m.category} · {m.prompt_slug}
                      </span>
                    </li>
                  ))}
                </ul>
              </div>
            )}
          </div>
        </li>
      ))}
    </ul>
  </section>
)}

<script>
  document
    .querySelectorAll<HTMLButtonElement>("[data-toggle-session]")
    .forEach((btn) => {
      btn.addEventListener("click", () => {
        const expanded = btn.dataset.expanded === "true";
        const next = !expanded;
        btn.dataset.expanded = String(next);
        btn.setAttribute("aria-expanded", String(next));
        const id = btn.dataset.sessionId;
        if (!id) return;
        const panel = document.querySelector<HTMLElement>(
          `[data-session-panel="${id}"]`,
        );
        if (panel) {
          if (next) panel.removeAttribute("hidden");
          else panel.setAttribute("hidden", "");
        }
        const icon = btn.querySelector<HTMLElement>("[data-icon]");
        if (icon) icon.textContent = next ? "↑" : "↓";
      });
    });
</script>
