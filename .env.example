# Copy this file to `.env` for local dev. In production, set these in the
# hosting provider's dashboard (Cloudflare Pages → Settings → Variables).
#
# The four vars below are independent of the benchmarkadmin app's env —
# each deployment has its own env, even though SUPABASE_URL and
# SUPABASE_ANON_KEY point to the same Supabase project.

# Subscriber capture (POST /api/subscribe)
SUPABASE_URL=
SUPABASE_ANON_KEY=

# Cloudflare Turnstile — optional but recommended for spam protection.
# Get keys from https://dash.cloudflare.com → Turnstile (free).
# If TURNSTILE_SECRET_KEY is unset the subscribe endpoint skips captcha
# verification, which is fine for local dev but DON'T ship to prod without it.
TURNSTILE_SECRET_KEY=
PUBLIC_TURNSTILE_SITE_KEY=

# Optional: override the canonical site URL used in sitemaps + RSS.
# SITE_URL=https://humanizerbench.example.com
